{
  "name": "queueglass",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "next typegen && tsc --noEmit",
    "test": "node --test tests/*.test.js",
    "test:browser": "node scripts/browser-smoke.mjs",
    "audit:claims": "node scripts/claim-scan.mjs",
    "audit:secrets": "node scripts/secret-scan.mjs",
    "verify": "npm run audit:claims && npm run audit:secrets && npm run lint && npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "next": "16.2.11",
    "react": "19.2.8",
    "react-dom": "19.2.8"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "16.2.11",
    "playwright": "^1.61.1",
    "typescript": "^5.0.0"
  },
  "overrides": {
    "postcss": "8.5.21",
    "sharp": "0.35.3"
  }
}
